#!/usr/bin/env bash
# serena-dash — 현재 프로젝트의 Serena MCP 대시보드를 브라우저에서 연다.
#
# 동작 방식:
#   1. 포트 24282-24290 중 Serena 가 응답하는 포트를 스캔
#   2. 각 포트의 PID 를 확인하고 /proc/<pid>/cwd (Linux) 로 프로세스 CWD 조회
#   3. CWD 가 현재 디렉터리와 일치하는 포트 → 브라우저로 열기
#   4. 일치하는 포트 없으면 응답하는 첫 포트를 fallback 으로 열기
#
# Usage:
#   serena-dash               # 현재 디렉터리 기준으로 포트 자동 탐색
#   serena-dash --list        # 실행 중인 Serena 인스턴스 목록 출력

set -uo pipefail

CWD="$(pwd -P)"
LIST_ONLY=0
[[ "${1:-}" == "--list" ]] && LIST_ONLY=1

BOLD='\033[1m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
RESET='\033[0m'

# PID 의 CWD 를 반환 (Linux /proc 우선, fallback lsof)
_proc_cwd() {
  local pid="$1"
  if [[ -L "/proc/$pid/cwd" ]]; then
    readlink -f "/proc/$pid/cwd" 2>/dev/null && return
  fi
  if command -v lsof >/dev/null 2>&1; then
    lsof -p "$pid" -a -d cwd -Fn 2>/dev/null | grep '^n' | sed 's/^n//' | head -1
  fi
}

# 브라우저 열기 (WSL2 / macOS / Linux)
_open_browser() {
  local url="$1"
  if grep -qi microsoft /proc/version 2>/dev/null; then
    cmd.exe /c start "" "$url" 2>/dev/null \
      || wslview "$url" 2>/dev/null \
      || xdg-open "$url" 2>/dev/null \
      || true
  elif [[ "$(uname -s)" == "Darwin" ]]; then
    open "$url"
  else
    xdg-open "$url" 2>/dev/null || true
  fi
}

# ── 스캔 ─────────────────────────────────────────────────────────────────────
declare -a FOUND_PORTS=()
declare -A PORT_CWD=()
MATCH_PORT=""

for p in 24282 24283 24284 24285 24286 24287 24288 24289 24290; do
  curl -sf "http://127.0.0.1:$p/dashboard/" >/dev/null 2>&1 || continue
  FOUND_PORTS+=("$p")

  # PID 조회
  pid=$(lsof -ti:"$p" 2>/dev/null | head -1) || true
  if [[ -n "$pid" ]]; then
    pcwd="$(_proc_cwd "$pid")"
    PORT_CWD["$p"]="${pcwd:-unknown}"
    if [[ "$pcwd" == "$CWD" ]]; then
      MATCH_PORT="$p"
    fi
  else
    PORT_CWD["$p"]="unknown"
  fi
done

# ── --list 모드 ───────────────────────────────────────────────────────────────
if [[ $LIST_ONLY -eq 1 ]]; then
  if [[ ${#FOUND_PORTS[@]} -eq 0 ]]; then
    echo -e "${YELLOW}실행 중인 Serena 인스턴스 없음${RESET}"
    exit 0
  fi
  echo -e "${BOLD}실행 중인 Serena 인스턴스:${RESET}"
  for p in "${FOUND_PORTS[@]}"; do
    marker=""
    [[ "$p" == "$MATCH_PORT" ]] && marker=" ${GREEN}← 현재 프로젝트${RESET}"
    echo -e "  포트 ${CYAN}$p${RESET}  ${PORT_CWD[$p]:-unknown}${marker}"
  done
  exit 0
fi

# ── 대시보드 열기 ─────────────────────────────────────────────────────────────
if [[ ${#FOUND_PORTS[@]} -eq 0 ]]; then
  echo -e "${RED}❌ Serena 대시보드를 찾을 수 없습니다.${RESET}"
  echo "   Claude Code 를 프로젝트 디렉터리에서 열면 Serena 가 자동으로 시작됩니다."
  exit 1
fi

if [[ -n "$MATCH_PORT" ]]; then
  URL="http://127.0.0.1:$MATCH_PORT/dashboard/index.html"
  echo -e "${GREEN}▸${RESET} Serena 대시보드 (포트 ${BOLD}$MATCH_PORT${RESET}, 현재 프로젝트): ${CYAN}$URL${RESET}"
else
  MATCH_PORT="${FOUND_PORTS[0]}"
  URL="http://127.0.0.1:$MATCH_PORT/dashboard/index.html"
  echo -e "${YELLOW}⚠  현재 프로젝트($(basename "$CWD"))와 일치하는 Serena 인스턴스를 찾지 못했습니다.${RESET}"
  echo -e "   첫 번째 응답 포트(${BOLD}$MATCH_PORT${RESET})를 엽니다: ${CYAN}$URL${RESET}"
fi

_open_browser "$URL"
