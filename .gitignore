# Local Claude Code settings (per-user permissions, overrides)
.claude/settings.local.json

# Local Codex project settings generated by project-codex.sh
.codex

# Impeccable external installer residue — not used by this repo
.agents/
skills-lock.json
/skills/

# fzf binary — large, platform-specific. Users run scripts/install-fzf.sh
bin/fzf

__pycache__/
*.pyc

# Machine-local registry of installed projects (never push)
.installed-projects
.installed-projects.codex
.worktrees/
.claude/worktrees/

# Serena MCP local data — ai-dev-setting 본체는 Serena 룰 미사용 프로젝트
# (bash/markdown 위주라 LSP 가치 낮음). Serena 가 자동 생성한 .serena/ 무시.
.serena/

# 헤르메스 로컬 DB — 프로젝트별 생성, 커밋 불필요
.hermes/
temp/

# Terminal Paste Image folder
.cp-images/

# 개인 작업 노트·외부 저작물 PDF — 공개/공유 대상 아님 (로컬 보관용)
.00_docs/

# ai-dev-setting 자체 dogfooding 작업기록 — 로컬만 (커밋 X).
# 설치 대상 프로젝트용 docs 구조·템플릿은 assets/docs-templates/ 가 배포하므로
# 원본 repo 에는 개인 작업로그를 올리지 않는다.
docs/exec-plans/active/
docs/exec-plans/completed/
docs/exec-plans/backlog/
docs/audits/
docs/superpowers/plans/
